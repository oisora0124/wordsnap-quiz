# WordBank デプロイ用の環境変数の例。実際の値はコミットしない。
# Cloudflare ダッシュボードまたは `wrangler d1 create wordbank` で取得する。

# 本番D1のデータベースID（wrangler.jsonc の REPLACE_WITH_YOUR_D1_DATABASE_ID に入れる）
CLOUDFLARE_D1_DATABASE_ID=

# ステージング用D1（本番と別DB。DEPLOY-005）
CLOUDFLARE_D1_DATABASE_ID_STAGING=

# Pages デプロイに使うアカウント/トークン（CIから注入）
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
